<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etDoctorFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Full Name" />

        <EditText
            android:id="@+id/etDoctorSpecialization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Specialization" />

        <EditText
            android:id="@+id/etDoctorLicense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="License Number" />

        <EditText
            android:id="@+id/etDoctorPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phone" />

        <EditText
            android:id="@+id/etDoctorEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email" />

        <EditText
            android:id="@+id/etDoctorAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Address" />

        <EditText
            android:id="@+id/etDoctorDepartmentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Department ID"
            android:inputType="number" />

        <Button
            android:id="@+id/btnSaveDoctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnDeleteDoctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>