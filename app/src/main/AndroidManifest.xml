        <activity android:name=".UI.Activities.User.UserListActivity" android:exported="false" />
        <activity android:name=".UI.Activities.User.UserFormActivity" android:exported="false" />
        <activity android:name=".UI.Activities.MedicalRecord.MedicalRecordListActivity" android:exported="false" />
        <activity android:name=".UI.Activities.MedicalRecord.MedicalRecordFormActivity" android:exported="false" />
        <activity android:name=".UI.Activities.Medication.MedicationListActivity" android:exported="false" />
        <activity android:name=".UI.Activities.Medication.MedicationFormActivity" android:exported="false" />
